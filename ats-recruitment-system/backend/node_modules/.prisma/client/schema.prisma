generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
}

enum JobStatus {
  DRAFT
  OPEN
  CLOSED
  ON_HOLD
}

enum InterviewStatus {
  SCHEDULED
  COMPLETED
  CANCELED
  NO_SHOW
}

model User {
  id           String    @id @default(uuid())
  firstName    String
  lastName     String
  email        String    @unique
  passwordHash String
  roleId       String
  departmentId String?
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  role               Role                 @relation(fields: [roleId], references: [id])
  department         Department?          @relation(fields: [departmentId], references: [id])
  createdJobs        Job[]                @relation("CreatedJobs")
  assignedCandidates Candidate[]          @relation("AssignedCandidates")
  notes              CandidateNote[]
  applicationChanges ApplicationHistory[]
  interviews         Interview[]
  interviewFeedback  InterviewFeedback[]
  notifications      Notification[]
  sentMessages       Message[]            @relation("SentMessages")
  receivedMessages   Message[]            @relation("ReceivedMessages")
  reports            Report[]
  resumesUploaded    Resume[]
  settingsUpdated    SystemSetting[]
  auditLogs          AuditLog[]

  @@index([roleId])
  @@index([departmentId])
  @@map("users")
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users           User[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  key         String   @unique
  label       String
  description String?
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(uuid())
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model Department {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())

  users User[]
  jobs  Job[]

  @@map("departments")
}

model Location {
  id        String   @id @default(uuid())
  name      String   @unique
  country   String?
  isRemote  Boolean  @default(false)
  createdAt DateTime @default(now())

  jobs Job[]

  @@map("locations")
}

model Skill {
  id        String   @id @default(uuid())
  name      String   @unique
  category  String?
  createdAt DateTime @default(now())

  jobSkills       JobSkill[]
  candidateSkills CandidateSkill[]

  @@map("skills")
}

model Job {
  id           String    @id @default(uuid())
  title        String
  description  String
  type         JobType
  status       JobStatus @default(DRAFT)
  minSalary    Int?
  maxSalary    Int?
  openings     Int       @default(1)
  departmentId String
  locationId   String
  createdById  String
  publishedAt  DateTime?
  closesAt     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  department   Department    @relation(fields: [departmentId], references: [id])
  location     Location      @relation(fields: [locationId], references: [id])
  createdBy    User          @relation("CreatedJobs", fields: [createdById], references: [id])
  skills       JobSkill[]
  applications Application[]

  @@index([departmentId])
  @@index([locationId])
  @@index([status])
  @@map("jobs")
}

model JobSkill {
  id         String   @id @default(uuid())
  jobId      String
  skillId    String
  isRequired Boolean  @default(true)
  createdAt  DateTime @default(now())

  job   Job   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([jobId, skillId])
  @@index([skillId])
  @@map("job_skills")
}

model Candidate {
  id              String   @id @default(uuid())
  firstName       String
  lastName        String
  email           String   @unique
  phone           String?
  yearsExperience Float?
  currentCompany  String?
  source          String?
  assignedToId    String?
  linkedInUrl     String?
  githubUrl       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  assignedTo   User?            @relation("AssignedCandidates", fields: [assignedToId], references: [id])
  skills       CandidateSkill[]
  resumes      Resume[]
  notes        CandidateNote[]
  applications Application[]
  messages     Message[]

  @@index([assignedToId])
  @@map("candidates")
}

model CandidateSkill {
  id          String   @id @default(uuid())
  candidateId String
  skillId     String
  proficiency Int?
  years       Float?
  createdAt   DateTime @default(now())

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  skill     Skill     @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([candidateId, skillId])
  @@index([skillId])
  @@map("candidate_skills")
}

model Resume {
  id           String    @id @default(uuid())
  candidateId  String
  uploadedById String?
  fileUrl      String?
  rawText      String?
  aiSummary    String?
  aiSkills     Json?
  aiExperience Json?
  parsedAt     DateTime?
  createdAt    DateTime  @default(now())

  candidate  Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  uploadedBy User?     @relation(fields: [uploadedById], references: [id])

  @@index([candidateId])
  @@map("resumes")
}

model CandidateNote {
  id          String   @id @default(uuid())
  candidateId String
  authorId    String
  content     String
  isPrivate   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  author    User      @relation(fields: [authorId], references: [id])

  @@index([candidateId])
  @@map("candidate_notes")
}

model Stage {
  id         String   @id @default(uuid())
  name       String   @unique
  order      Int      @unique
  isTerminal Boolean  @default(false)
  createdAt  DateTime @default(now())

  applications Application[]
  fromHistory  ApplicationHistory[] @relation("FromStage")
  toHistory    ApplicationHistory[] @relation("ToStage")
  interviews   Interview[]

  @@map("stages")
}

model Application {
  id             String   @id @default(uuid())
  candidateId    String
  jobId          String
  currentStageId String
  source         String?
  score          Float?
  coverLetter    String?
  appliedAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  candidate     Candidate            @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  job           Job                  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  currentStage  Stage                @relation(fields: [currentStageId], references: [id])
  history       ApplicationHistory[]
  interviews    Interview[]
  notifications Notification[]

  @@unique([candidateId, jobId])
  @@index([currentStageId])
  @@index([jobId])
  @@map("applications")
}

model ApplicationHistory {
  id            String   @id @default(uuid())
  applicationId String
  fromStageId   String?
  toStageId     String
  changedById   String
  note          String?
  changedAt     DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  fromStage   Stage?      @relation("FromStage", fields: [fromStageId], references: [id])
  toStage     Stage       @relation("ToStage", fields: [toStageId], references: [id])
  changedBy   User        @relation(fields: [changedById], references: [id])

  @@index([applicationId])
  @@map("application_history")
}

model Interview {
  id              String          @id @default(uuid())
  applicationId   String
  stageId         String
  interviewerId   String
  scheduledAt     DateTime
  durationMinutes Int             @default(60)
  meetingLink     String?
  status          InterviewStatus @default(SCHEDULED)
  createdAt       DateTime        @default(now())

  application Application         @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  stage       Stage               @relation(fields: [stageId], references: [id])
  interviewer User                @relation(fields: [interviewerId], references: [id])
  feedback    InterviewFeedback[]

  @@index([applicationId])
  @@map("interviews")
}

model InterviewFeedback {
  id             String   @id @default(uuid())
  interviewId    String
  reviewerId     String
  rating         Int
  strengths      String?
  concerns       String?
  recommendation String?
  createdAt      DateTime @default(now())

  interview Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  reviewer  User      @relation(fields: [reviewerId], references: [id])

  @@index([interviewId])
  @@map("interview_feedback")
}

model Notification {
  id            String    @id @default(uuid())
  userId        String
  applicationId String?
  type          String
  title         String
  body          String
  readAt        DateTime?
  createdAt     DateTime  @default(now())

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  application Application? @relation(fields: [applicationId], references: [id], onDelete: SetNull)

  @@index([userId, readAt])
  @@map("notifications")
}

model Message {
  id          String    @id @default(uuid())
  senderId    String
  receiverId  String
  candidateId String?
  content     String
  sentAt      DateTime  @default(now())
  readAt      DateTime?

  sender    User       @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver  User       @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  candidate Candidate? @relation(fields: [candidateId], references: [id], onDelete: SetNull)

  @@index([senderId, receiverId])
  @@map("messages")
}

model Report {
  id          String   @id @default(uuid())
  name        String
  type        String
  filtersJson Json?
  resultJson  Json?
  createdById String
  generatedAt DateTime @default(now())

  createdBy User @relation(fields: [createdById], references: [id])

  @@index([createdById])
  @@map("reports")
}

model SystemSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  updatedById String?
  updatedAt   DateTime @updatedAt

  updatedBy User? @relation(fields: [updatedById], references: [id])

  @@map("system_settings")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@map("audit_logs")
}
